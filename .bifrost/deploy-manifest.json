{
  "version": "1",
  "owner": "mock1ngbb",
  "repo": "nervous",
  "targets": [
    {
      "service_id": "cf-worker:nervous-system-states:production",
      "platform": "cf-worker",
      "build": {
        "install_cmd": "true",
        "build_cmd": "true"
      },
      "artifact": {
        "type": "worker-script",
        "worker_name": "nervous-system-states",
        "bundle_path": "worker/src/index.js"
      },
      "health_check": {
        "url": "https://nervous.mock1ngbb.com/",
        "timeout_seconds": 30,
        "retry_count": 3,
        "expected_status": 200
      },
      "rollback_strategy": "previous-version",
      "watch_paths": ["worker/**", "site/**"],
      "deploy_branch": "main",
      "destructive_gate": false,
      "max_deploy_time_seconds": 300,
      "concurrent_deploys": "serial"
    }
  ],
  "secrets": ["CF_ADMIN_TOKEN", "CF_WORKERS_TOKEN"],
  "env": {}
}
